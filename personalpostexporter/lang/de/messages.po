msgstr "Wähle den Zeitraum für deinen Export."

#: personalpostexporter.php
msgid "All Time"
msgstr "Gesamter Zeitraum"

#: personalpostexporter.php
msgid "Older than 10 years"
msgstr "Älter als 10 Jahre"

#: personalpostexporter.php
msgid "Start Export"
msgstr "Export starten"

