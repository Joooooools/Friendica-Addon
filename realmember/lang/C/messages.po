#: realmember.php:504
msgid "📖 What can RealMember do?"
msgstr "📖 What can RealMember do?"

#: realmember.php:505
msgid "✅ What RealMember can do"
msgstr "✅ What RealMember can do"

#: realmember.php:506
msgid "<strong>Risk assessment of all users:</strong> Every registered account is automatically analyzed based on multiple criteria and receives a risk score from 0% to 100%."
msgstr "<strong>Risk assessment of all users:</strong> Every registered account is automatically analyzed based on multiple criteria and receives a risk score from 0% to 100%."

#: realmember.php:507
msgid "<strong>Disposable email detection:</strong> Email addresses are checked against a community-maintained list of thousands of known disposable providers."
msgstr "<strong>Disposable email detection:</strong> Email addresses are checked against a community-maintained list of thousands of known disposable providers."

#: realmember.php:508
msgid "<strong>Detect suspicious domains:</strong> Domain extensions (TLDs) commonly abused for spam are automatically detected."
msgstr "<strong>Detect suspicious domains:</strong> Domain extensions (TLDs) commonly abused for spam are automatically detected."

#: realmember.php:509
msgid "<strong>Keyword scan:</strong> Usernames and registration notes are searched for almost 200 suspicious terms from the fields of pharma, crypto, erotics, and marketing."
msgstr "<strong>Keyword scan:</strong> Usernames and registration notes are searched for almost 200 suspicious terms from the fields of pharma, crypto, erotics, and marketing."

#: realmember.php:510
msgid "<strong>Bot detection (entropy):</strong> Randomly generated nicknames and email prefixes without natural word structure are detected using pattern analysis."
msgstr "<strong>Bot detection (entropy):</strong> Randomly generated nicknames and email prefixes without natural word structure are detected using pattern analysis."

#: realmember.php:511
msgid "<strong>Include admin rules:</strong> Your own email blocklists from Friendica settings are automatically included in the assessment."
msgstr "<strong>Include admin rules:</strong> Your own email blocklists from Friendica settings are automatically included in the assessment."

#: realmember.php:512
msgid "<strong>Filtering & Sorting:</strong> You can filter and sort results by time period, suspected spam, name, email, or risk score."
msgstr "<strong>Filtering & Sorting:</strong> You can filter and sort results by time period, suspected spam, name, email, or risk score."

#: realmember.php:513
msgid "<strong>Search:</strong> A full-text search across names, handles, and email addresses is integrated."
msgstr "<strong>Search:</strong> A full-text search across names, handles, and email addresses is integrated."

#: realmember.php:514
msgid "<strong>Automatic updates:</strong> The disposable domain list can be automatically updated daily via a cron job."
msgstr "<strong>Automatic updates:</strong> The disposable domain list can be automatically updated daily via a cron job."

#: realmember.php:515
msgid "<strong>Seamless integration:</strong> RealMember appears as a tab in Friendica moderation and blends seamlessly into the existing interface."
msgstr "<strong>Seamless integration:</strong> RealMember appears as a tab in Friendica moderation and blends seamlessly into the existing interface."

#: realmember.php:517
msgid "🔒 Security Guarantee"
msgstr "🔒 Security Guarantee"

#: realmember.php:518
msgid "<strong>Read-only:</strong> RealMember exclusively reads data. No database entries are created, modified, or deleted."
msgstr "<strong>Read-only:</strong> RealMember exclusively reads data. No database entries are created, modified, or deleted."

#: realmember.php:519
msgid "<strong>No automated actions:</strong> RealMember never blocks, deletes, or modifies any account automatically. All decisions are made by the admin."
msgstr "<strong>No automated actions:</strong> RealMember never blocks, deletes, or modifies any account automatically. All decisions are made by the admin."

#: realmember.php:520
msgid "<strong>Only for admins:</strong> The dashboard is only visible to site administrators."
msgstr "<strong>Only for admins:</strong> The dashboard is only visible to site administrators."

#: realmember.php:522
msgid "⚠️ What RealMember cannot do"
msgstr "⚠️ What RealMember cannot do"

#: realmember.php:523
msgid "<strong>No guarantee:</strong> RealMember is an assistance system. Not every flagged account is actually spam, and not every spammer will be detected."
msgstr "<strong>No guarantee:</strong> RealMember is an assistance system. Not every flagged account is actually spam, and not every spammer will be detected."

#: realmember.php:524
msgid "<strong>No content scan:</strong> Published posts, comments, or messages of users are not analyzed."
msgstr "<strong>No content scan:</strong> Published posts, comments, or messages of users are not analyzed."

#: realmember.php:525
msgid "<strong>No real-time monitoring:</strong> The analysis runs on every page load. There are no push notifications for new suspected spam cases."
msgstr "<strong>No real-time monitoring:</strong> The analysis runs on every page load. There are no push notifications for new suspected spam cases."

#: realmember.php:526
msgid "<strong>No deletion or blocking:</strong> RealMember cannot block or delete accounts. Use Friendica's moderation area for this."
msgstr "<strong>No deletion or blocking:</strong> RealMember cannot block or delete accounts. Use Friendica's moderation area for this."

